# ============================================================
# CreatorZap — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control!

# ─────────────────────────────────────────
# DATABASE (PostgreSQL via Railway or Supabase)
# ─────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/creatorzap?sslmode=require"

# ─────────────────────────────────────────
# JWT Authentication
# ─────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# ─────────────────────────────────────────
# AI Provider (OpenAI-compatible)
# ─────────────────────────────────────────
# Option 1: OpenAI
AI_BASE_URL="https://api.openai.com/v1"
AI_API_KEY="sk-..."
AI_MODEL="gpt-4o-mini"
# Optional aliases also supported by the code:
# OPENAI_BASE_URL="https://api.openai.com/v1"
# OPENAI_API_KEY="sk-..."
# OPENAI_MODEL="gpt-4o-mini"

# Option 2: Together AI (cheaper, recommended for Africa)
# AI_BASE_URL="https://api.together.xyz/v1"
# AI_API_KEY="your-together-ai-key"
# AI_MODEL="mistralai/Mixtral-8x7B-Instruct-v0.1"

# Option 3: Groq (free tier available)
# AI_BASE_URL="https://api.groq.com/openai/v1"
# AI_API_KEY="your-groq-key"
# AI_MODEL="llama3-8b-8192"

# Option 4: OpenRouter (access to many models)
# AI_BASE_URL="https://openrouter.ai/api/v1"
# AI_API_KEY="your-openrouter-key"
# AI_MODEL="meta-llama/llama-3-8b-instruct"

# ─────────────────────────────────────────
# Fapshi Payment Gateway
# Docs: https://fapshi.com/docs
# ─────────────────────────────────────────
FAPSHI_API_USER="your-fapshi-api-user"
FAPSHI_API_KEY="your-fapshi-api-key"

# ─────────────────────────────────────────
# App Configuration
# ─────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Production: NEXT_PUBLIC_APP_URL="https://creatorzap.vercel.app"

NODE_ENV="development"

# Admin bootstrap / auto-admin
ADMIN_EMAIL="admin@example.com"
# Or multiple emails separated by commas
ADMIN_EMAILS="admin@example.com,teamlead@example.com"
ADMIN_PASSWORD="change-me-if-you-use-seeding"
ADMIN_NAME="CreatorZap Admin"

# Downloader provider (cobalt-compatible API recommended)
DOWNLOAD_PROVIDER_URL="https://api.cobalt.tools/api/json"
# DOWNLOAD_PROVIDER_TOKEN=""
